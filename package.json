{
	"name": "pikacss-monorepo",
	"type": "module",
	"version": "0.0.47",
	"private": true,
	"packageManager": "pnpm@10.30.2",
	"description": "The instant on-demand atomic css-in-js engine.",
	"author": "DevilTea <ch19980814@gmail.com>",
	"license": "MIT",
	"keywords": [
		"pikacss",
		"atomic-css",
		"css-in-js",
		"atomic-css-in-js-engine"
	],
	"scripts": {
		"build": "pnpm -r --filter='./packages/*' build",
		"newpkg": "tsx ./scripts/newpkg.ts",
		"newplugin": "tsx ./scripts/newplugin.ts",
		"publint": "pnpm -r --filter='./packages/*' exec publint",
		"publish:packages": "pnpm -r --filter='./packages/*' publish --no-git-checks",
		"release": "pnpm build && pnpm docs:build && pnpm typecheck && pnpm publint && rimraf ./**/dist && bumpp -r",
		"docs:dev": "pnpm -r --filter=@pikacss/docs run dev",
		"repopack": "tsx ./scripts/repopack.ts",
		"docs:build": "pnpm -r --filter=@pikacss/docs run build",
		"docs:preview": "pnpm -r --filter=@pikacss/docs run preview",
		"docs:check-examples": "tsx ./scripts/check-docs-examples.ts",
		"docs:verify-examples": "vitest run --project docs-examples",
		"docs:update-examples": "vitest run --project docs-examples --update",
		"typecheck": "pnpm -r typecheck",
		"test": "vitest run",
		"lint": "eslint --fix .",
		"prepare": "simple-git-hooks"
	},
	"devDependencies": {
		"@clack/prompts": "catalog:",
		"@deviltea/eslint-config": "catalog:",
		"@deviltea/tsconfig": "catalog:",
		"@mdn/browser-compat-data": "catalog:",
		"@pikacss/eslint-config": "workspace:*",
		"@types/node": "catalog:",
		"@vitest/coverage-v8": "catalog:",
		"bumpp": "catalog:",
		"eslint": "catalog:",
		"happy-dom": "catalog:",
		"lint-staged": "catalog:",
		"mdn-data": "catalog:",
		"pathe": "catalog:",
		"pkg-pr-new": "catalog:",
		"pkg-size": "catalog:",
		"publint": "catalog:",
		"repomix": "catalog:",
		"rimraf": "catalog:",
		"simple-git-hooks": "catalog:",
		"tsdown": "catalog:",
		"tsx": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:",
		"vue-tsc": "catalog:",
		"web-features": "catalog:",
		"zx": "catalog:"
	},
	"simple-git-hooks": {
		"pre-commit": "pnpm lint-staged"
	},
	"lint-staged": {
		"*": "eslint --fix"
	}
}
